	<key>NSLocationWhenInUseUsageDescription</key>
	<string>My Office Days uses your location to check if you're at a tracked office.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>My Office Days needs background location access to automatically detect when you arrive at a tracked office, even when the app is closed.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
